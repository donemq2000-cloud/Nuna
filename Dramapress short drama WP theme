                </div>
            `;
            list.insertAdjacentHTML('afterbegin', commentHTML);
            input.value = '';
            showToast("Komentar Dikirim!", "Komentar Anda berhasil diposting di website.", "success");
        }

        function showCoinStore() {
            STATE.currentView = 'coinstore';
            renderActiveView();
        }

        // TOAST NOTIFICATIONS HELPER
        function showToast(title, msg, type = 'success') {
            const container = document.getElementById('toast-container');
            const toastId = 'toast-' + Math.random().toString(36).substr(2, 9);
            
            let bg = 'bg-slate-900 border-slate-800';
            let iconColor = 'text-green-400';
            let icon = 'fa-check-circle';

            if (type === 'error') {
                iconColor = 'text-red-400';
                icon = 'fa-exclamation-circle';
            } else if (type === 'info') {
                iconColor = 'text-sky-400';
                icon = 'fa-info-circle';
            }

            const toastHTML = `
                <div id="${toastId}" class="flex items-center gap-3 p-4 rounded-xl shadow-2xl border ${bg} text-xs text-slate-300 transform translate-y-5 opacity-0 transition duration-300 max-w-sm">
                    <i class="fas ${icon} ${iconColor} text-lg shrink-0"></i>
                    <div>
                        <strong class="text-slate-100 block font-bold">${title}</strong>
                        <span class="text-slate-400">${msg}</span>
                    </div>
                </div>
            `;

            container.insertAdjacentHTML('beforeend', toastHTML);
            const el = document.getElementById(toastId);
            
            // Trigger animation
            setTimeout(() => {
                el.classList.remove('translate-y-5', 'opacity-0');
            }, 50);

            // Hide and remove
            setTimeout(() => {
                el.classList.add('translate-y-5', 'opacity-0');
                setTimeout(() => el.remove(), 300);
            }, 3000);
        }
    </script>
