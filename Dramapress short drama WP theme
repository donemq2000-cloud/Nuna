        // UTILITY: COUNTS AND COUNTERS UPDATE IN SIDEBAR
        function updateStatsCounts() {
            const dramaBadge = document.getElementById('wp-count-dramas');
            if (dramaBadge) dramaBadge.textContent = STATE.dramas.length;

            const episodeBadge = document.getElementById('wp-count-episodes');
            if (episodeBadge) episodeBadge.textContent = STATE.episodes.length;
        }

        // UTILITY: CLIENT-SIDE INTERACTIONS
        function toggleLike(btn) {
            const icon = btn.querySelector('i');
            if (icon.classList.contains('fas')) {
                icon.classList.replace('fas', 'far');
                icon.classList.remove('text-red-500');
                showToast("Dihapus!", "Batal menyukai video ini.", "info");
            } else {
                icon.classList.replace('far', 'fas');
                icon.classList.add('text-red-500');
                icon.classList.add('animate-heart');
                setTimeout(() => icon.classList.remove('animate-heart'), 800);
                showToast("Disukai!", "Video berhasil ditambahkan ke daftar suka Anda.", "success");
            }
        }

        function scrollToComments() {
