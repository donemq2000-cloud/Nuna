        function saveDrama(e) {
            e.preventDefault();

            const title = document.getElementById('form-drama-title').value;
            const genre = document.getElementById('form-drama-genre').value;
            const cast = document.getElementById('form-drama-cast').value;
            const cover = document.getElementById('form-drama-cover').value;
            const status = document.getElementById('form-drama-status').value;
            const rating = document.getElementById('form-drama-rating').value || "4.8";
            const desc = document.getElementById('form-drama-desc').value;

            if (STATE.editingDrama) {
                // Update
                const d = STATE.dramas.find(item => item.id === STATE.editingDrama.id);
                if (d) {
                    d.title = title;
                    d.genre = genre;
                    d.cast = cast;
                    d.cover = cover;
                    d.status = status;
                    d.rating = rating;
                    d.description = desc;
                    showToast("Sukses!", "Pos Drama berhasil diperbarui di database WP.", "success");
                }
            } else {
                // Insert New
                const newId = STATE.dramas.length > 0 ? Math.max(...STATE.dramas.map(item => item.id)) + 1 : 1;
                STATE.dramas.push({
                    id: newId,
                    title,
                    slug: title.toLowerCase().replace(/ /g, '-'),
                    genre,
                    status,
                    views: 0,
                    rating,
                    cover,
                    description: desc,
                    cast,
                    trending: false
                });
                showToast("Sukses!", "Drama baru berhasil dipublikasikan!", "success");
            }

            closeDramaForm();
            switchAdminTab('dramas');
            updateStatsCounts();
        }

