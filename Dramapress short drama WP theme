            `;
        }

        function openEpisodeForm() {
            STATE.editingEpisode = null;
            document.getElementById('episode-form-title').innerText = "Upload Episode Baru";
            document.getElementById('form-ep-title').value = '';
            document.getElementById('form-ep-num').value = STATE.episodes.length + 1;
            document.getElementById('form-ep-freetest').value = "true";
            document.getElementById('form-ep-coincost').value = "0";
            document.getElementById('form-ep-coincost').disabled = true;
            document.getElementById('form-ep-coincost').classList.add('bg-slate-50');
            document.getElementById('form-ep-duration').value = '2:00';
            document.getElementById('form-ep-src').value = 'https://assets.mixkit.co/videos/preview/mixkit-rainy-night-in-a-neon-lit-city-42099-large.mp4';
            document.getElementById('form-ep-caption').value = '';

            document.getElementById('episode-form-panel').classList.remove('hidden');
        }

        function closeEpisodeForm() {
            document.getElementById('episode-form-panel').classList.add('hidden');
        }

        function toggleFormCoinCost() {
            const isFree = document.getElementById('form-ep-freetest').value === "true";
            const costInput = document.getElementById('form-ep-coincost');
            if (isFree) {
                costInput.value = "0";
                costInput.disabled = true;
                costInput.classList.add('bg-slate-50');
            } else {
                costInput.value = "15";
                costInput.disabled = false;
                costInput.classList.remove('bg-slate-50');
            }
        }

        function saveEpisode(e) {
            e.preventDefault();

            const dramaId = parseInt(document.getElementById('form-ep-parent').value);
            const title = document.getElementById('form-ep-title').value;
            const epNum = parseInt(document.getElementById('form-ep-num').value);
            const isFree = document.getElementById('form-ep-freetest').value === "true";
            const coinCost = parseInt(document.getElementById('form-ep-coincost').value);
            const duration = document.getElementById('form-ep-duration').value;
            const videoSrc = document.getElementById('form-ep-src').value;
            const caption = document.getElementById('form-ep-caption').value;

            if (STATE.editingEpisode) {
                // Update existing
                const ep = STATE.episodes.find(item => item.id === STATE.editingEpisode.id);
                if (ep) {
                    ep.dramaId = dramaId;
                    ep.title = title;
                    ep.epNum = epNum;
                    ep.isFree = isFree;
                    ep.coinCost = coinCost;
                    ep.duration = duration;
                    ep.videoSrc = videoSrc;
                    ep.caption = caption;
                    showToast("Sukses!", "Episode berhasil diperbarui di database WP.", "success");
                }
            } else {
                // Add new
                const newId = STATE.episodes.length > 0 ? Math.max(...STATE.episodes.map(item => item.id)) + 1 : 1;
                STATE.episodes.push({
                    id: newId,
                    dramaId,
                    epNum,
                    title,
                    isFree,
                    coinCost,
                    duration,
                    videoSrc,
                    caption
                });
                showToast("Sukses!", "Episode baru berhasil ditambahkan!", "success");
            }

            closeEpisodeForm();
            switchAdminTab('episodes');
            updateStatsCounts();
        }

        function editEpisode(id) {
            const ep = STATE.episodes.find(item => item.id === id);
            if (!ep) return;

            STATE.editingEpisode = ep;
            document.getElementById('episode-form-title').innerText = `Edit Episode: ${ep.title}`;
            document.getElementById('form-ep-parent').value = ep.dramaId;
            document.getElementById('form-ep-title').value = ep.title;
            document.getElementById('form-ep-num').value = ep.epNum;
            document.getElementById('form-ep-freetest').value = ep.isFree ? "true" : "false";
            document.getElementById('form-ep-coincost').value = ep.coinCost;
            document.getElementById('form-ep-coincost').disabled = ep.isFree;
            if (ep.isFree) {
                document.getElementById('form-ep-coincost').classList.add('bg-slate-50');
            } else {
                document.getElementById('form-ep-coincost').classList.remove('bg-slate-50');
            }
            document.getElementById('form-ep-duration').value = ep.duration;
            document.getElementById('form-ep-src').value = ep.videoSrc;
            document.getElementById('form-ep-caption').value = ep.caption || '';

            document.getElementById('episode-form-panel').classList.remove('hidden');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function deleteEpisode(id) {
            if (confirm("Hapus episode ini? Tindakan ini permanen.")) {
                STATE.episodes = STATE.episodes.filter(ep => ep.id !== id);
                showToast("Dihapus!", "Episode berhasil dihapus dari database.", "success");
                switchAdminTab('episodes');
                updateStatsCounts();
            }
        }


