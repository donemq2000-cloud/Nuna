        function addComment() {
            const input = document.getElementById('new-comment-input');
            const text = input.value.trim();
            if (!text) return;

            const list = document.getElementById('player-comment-list');
            const commentHTML = `
                <div class="flex gap-2.5 animate-pulse">
                    <div class="w-7 h-7 rounded-full bg-violet-600 flex items-center justify-center text-[10px] text-white shrink-0">AD</div>
